""" Calculating the factorial using recursion """

def fact_rec(num):
   if num == 1:
      return 1
   else:
       factorial = num * fact_rec(num -1)
       return factorial


number = 5   #Sample number
number = (int(input("Enter a number: "))) 
print(f"Factorial of {number} is: {fact_rec(number)}")



""" Using a math module for Calculations such as square root, Logarithm, Sine. """

import math
num = int(input("Enter a number: "))
output = math.sqrt(num)
print(f"square root: {output}")
print("===================")
output = math.log(num)
print(f"Logarithm: {output}")
print("====================")
output = math.sin(num)
print(f"Sine: {output}")
print("====================")


